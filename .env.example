VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# --- "Teach the AI" tutor step (Claude / Anthropic) ---
# Without a key, the teach-back step shows an "unavailable" notice and you
# continue to the final check (no fake responses). Set a key to turn on the real
# Claude tutor.
# WARNING: this calls the Anthropic API directly from the browser, so the key is
# exposed in the client bundle. Use a throwaway/dev key, or proxy via a backend
# for production.
VITE_ANTHROPIC_API_KEY=
# Defaults to claude-opus-4-8; set the exact model slug your key can access.
VITE_ANTHROPIC_MODEL=
