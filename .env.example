VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# --- "Teach the AI" tutor step (ChatGPT / OpenAI) ---
# The tutor runs through a Cloud Function (functions/index.js), so the OpenAI key
# lives ONLY server-side and is never in this client bundle. There is no client
# env var for it. To enable the tutor:
#   1. firebase functions:secrets:set OPENAI_API_KEY   (paste the key at the prompt)
#   2. deploy functions + hosting (npm run build && firebase deploy)
# When the app can't reach the function (e.g. Firebase not configured), the
# teach-back step falls back to a written self-check against the lesson's rubric,
# so the lesson still works end to end.
